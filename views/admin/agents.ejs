<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Équipe d'Agents — SAS Parking</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<button class="menu-toggle" onclick="toggleSidebar()">☰</button>
<div class="app-layout">
  <%- include('../composants/sidebar_admin', { page:'agents', adminNom, adminPrenom }) %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left">
        <div class="topbar-title">Équipe d'Agents</div>
        <div class="topbar-sub"><%= new Date().toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></div>
      </div>
      <div class="topbar-right">
        <button class="btn btn-primary" onclick="openModal('modalAjout')">+ Ajouter un agent</button>
        <div class="topbar-user">
          <div class="topbar-avatar"><%= (adminNom||'A')[0].toUpperCase() %></div>
          <div><div class="topbar-user-name"><%= adminNom %> <%= adminPrenom %></div><div class="topbar-user-role">Administrateur</div></div>
        </div>
      </div>
    </div>
    <div class="page-body">
      <% if (error)   { %><div class="alert alert-error   alert-auto-dismiss"><span>⚠️</span><span><%= error %></span></div><% } %>
      <% if (success) { %><div class="alert alert-success alert-auto-dismiss"><span>✅</span><span><%= success %></span></div><% } %>

      <!-- Recherche -->
      <form method="GET" action="/agents" class="search-bar">
        <div class="search-input-wrap">
          <span class="icon">🔍</span>
          <input type="text" name="search" class="form-control search-input" placeholder="Rechercher un agent par nom ou ID..." value="<%= search %>">
        </div>
        <select name="site" class="form-control" style="width:180px">
          <option value="">Tous les sites</option>
        </select>
        <button type="submit" class="btn btn-outline">Filtrer</button>
      </form>

      <!-- Grille agents -->
      <% if (agents.length === 0) { %>
        <div class="card" style="text-align:center;padding:48px">
          <div style="font-size:48px;margin-bottom:12px">👥</div>
          <div style="font-size:16px;font-weight:600;margin-bottom:8px">Aucun agent trouvé</div>
          <div style="color:#6b7280;margin-bottom:20px">Commencez par recruter votre premier agent de terrain.</div>
          <button class="btn btn-primary" onclick="openModal('modalAjout')">+ Recruter un agent</button>
        </div>
      <% } else { %>
        <div class="agents-grid">
          <% agents.forEach(agent => { %>
            <div class="agent-card">
              <div class="agent-card-header">
                <div style="display:flex;align-items:center;gap:12px">
                  <div class="agent-avatar initials"><%= (agent.nom||'?')[0].toUpperCase() %></div>
                  <div>
                    <div class="agent-name"><%= agent.nom %> <%= agent.prenom %></div>
                    <div class="agent-sub">📱 <%= agent.telephone %></div>
                  </div>
                </div>
                <div class="agent-status">
                  <span class="status-dot <%= agent.en_cours > 0 ? 'online' : 'offline' %>"></span>
                  <span style="font-size:11px;color:<%= agent.en_cours > 0 ? '#15803d':'#9ca3af' %>"><%= agent.en_cours > 0 ? 'En ligne':'Hors ligne' %></span>
                </div>
              </div>

              <div class="agent-stats">
                <div><div class="agent-stat-label">Début</div><div class="agent-stat-value">—</div></div>
                <div><div class="agent-stat-label">Sessions</div><div class="agent-stat-value"><%= agent.nb_sessions||0 %></div></div>
                <div><div class="agent-stat-label">Caisse</div><div class="agent-stat-value green"><%= Number(agent.total_encaisse||0).toLocaleString('fr-FR') %></div></div>
              </div>

              <div class="agent-actions">
                <a href="/historique?agent=<%= agent.id %>" class="btn btn-outline btn-sm" style="flex:1;justify-content:center">Historique →</a>
                <form action="/agents/toggle/<%= agent.id %>" method="POST" style="margin:0">
                  <button type="submit" class="btn btn-sm <%= agent.actif ? 'btn-ghost':'btn-primary' %>"
                    data-confirm="<%= agent.actif ? 'Désactiver cet agent ?':'Réactiver cet agent ?' %>">
                    <%= agent.actif ? '⏸':'▶' %>
                  </button>
                </form>
                <form action="/agents/delete/<%= agent.id %>" method="POST" style="margin:0">
                  <button type="submit" class="btn btn-danger btn-sm btn-icon" data-confirm="Supprimer définitivement cet agent ?">🗑</button>
                </form>
              </div>
            </div>
          <% }) %>

          <!-- Card recruter -->
          <div class="agent-card" style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;min-height:200px;cursor:pointer;border-style:dashed" onclick="openModal('modalAjout')">
            <div style="font-size:32px;color:#9ca3af">+</div>
            <div style="font-weight:600;color:#6b7280">Recruter un nouvel agent</div>
            <div style="font-size:12px;color:#9ca3af;text-align:center">Configurez un nouveau profil et assignez-le à votre site</div>
          </div>
        </div>
      <% } %>

      <!-- Footer totaux -->
      <% if (agents.length > 0) { %>
        <div style="display:flex;gap:24px;padding:16px 0;font-size:13px;color:#6b7280;border-top:1px solid #e5e7eb;margin-top:24px;flex-wrap:wrap">
          <span>Total agents : <strong style="color:#1f2937"><%= agents.length %></strong></span>
          <span>Actifs : <strong style="color:#15803d"><%= agents.filter(a=>a.actif).length %></strong></span>
          <span>Caisse cumulée aujourd'hui : <strong style="color:#15803d;font-size:16px"><%= agents.reduce((s,a)=>s+Number(a.total_encaisse||0),0).toLocaleString('fr-FR') %> FCFA</strong></span>
        </div>
      <% } %>
    </div>
    <div class="page-footer">
      <span>© <%= new Date().getFullYear() %> SAS Parking Bénin</span>
      <div class="footer-links"><a href="#">Support</a><a href="#">Confidentialité</a></div>
    </div>
  </div>
</div>

<!-- Modal ajout agent -->
<div class="modal-overlay hidden" id="modalAjout" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Ajouter un agent</div>
      <button class="modal-close" onclick="closeModal('modalAjout')">✕</button>
    </div>
    <form action="/agents/create" method="POST">
      <div class="modal-body">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Nom <span class="req">*</span></label>
            <input type="text" name="nom" class="form-control" placeholder="Koffi" required>
          </div>
          <div class="form-group">
            <label class="form-label">Prénom <span class="req">*</span></label>
            <input type="text" name="prenom" class="form-control" placeholder="Mensah" required>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Téléphone / Identifiant <span class="req">*</span></label>
          <div style="display:flex;gap:8px;align-items:center">
  <div style="background:#f3f4f6;border:1px solid #e5e7eb;border-radius:8px;padding:0 12px;height:44px;display:flex;align-items:center;font-weight:700;color:#374151;font-size:14px;white-space:nowrap">
    🇧🇯 +229
  </div>
  <input type="tel" name="telephone" class="form-control"
    placeholder="0X XX XX XX XX"
    pattern="[0-9]{10}"
    maxlength="10"
    title="10 chiffres sans indicatif"
    oninput="this.value=this.value.replace(/[^0-9]/g,'')"
    required>
</div>
        </div>
        <div class="form-group">
          <label class="form-label">Code PIN <span class="req">*</span></label>
          <div style="position:relative">
  <input type="password" name="mot_de_passe" minlength="4" maxlength="10" title="Entre 4 et 10 caractères" id="mdp-agent" class="form-control" placeholder="Min. 6 caractères" minlength="6" required>
  <button type="button" onclick="toggleMdp('mdp-agent')" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;display:flex;align-items:center">
    <svg id="eye-mdp-agent" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
    </svg>
  </button>
</div>
          <div class="form-hint">Ce code PIN sera utilisé par l'agent pour se connecter.</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('modalAjout')">Annuler</button>
        <button type="submit" class="btn btn-primary">Créer l'agent</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
function toggleMdp(id) {
  const input = document.getElementById(id);
  const isVisible = input.type === 'text';
  input.type = isVisible ? 'password' : 'text';
  const eye = document.getElementById('eye-' + id);
  eye.innerHTML = isVisible
    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
    : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
}
</script>
</body>
</html>
