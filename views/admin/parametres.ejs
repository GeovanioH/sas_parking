<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Paramètres — SAS Parking Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<button class="menu-toggle" onclick="toggleSidebar()">☰</button>

<div class="app-layout">
  <%- include('../composants/sidebar_admin', { page: 'parametres', adminNom, adminPrenom }) %>

  <div class="main-content">
    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-left">
        <div class="topbar-title">Paramètres</div>
        <div class="topbar-sub">Configuration du site parking</div>
      </div>
      <div class="topbar-right">
        <div class="topbar-user">
          <div class="topbar-avatar"><%= (adminNom||'A')[0].toUpperCase() %></div>
          <div>
            <div class="topbar-user-name"><%= adminNom %> <%= adminPrenom %></div>
            <div class="topbar-user-role">Administrateur</div>
          </div>
          <div class="topbar-online-dot"></div>
        </div>
      </div>
    </div>

    <div class="page-body">
      <% if (error) { %>
        <div class="alert alert-error alert-auto-dismiss"><span>⚠️</span><span><%= error %></span></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success alert-auto-dismiss"><span>✅</span><span><%= success %></span></div>
      <% } %>

      <!-- ONGLETS -->
      <div class="tabs-nav" id="tabsNav">
        <button class="tab-btn active" data-tab="infos">🏢 Informations</button>
        <button class="tab-btn" data-tab="tarifs">💰 Tarification</button>
        <button class="tab-btn" data-tab="agents">👥 Agents assignés</button>
      </div>

      <!-- ONGLET 1 : INFORMATIONS -->
      <div class="tab-panel active" id="tab-infos">
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Informations du parking</div>
              <div class="card-sub">Nom, ville et capacité de votre site</div>
            </div>
          </div>
          <div class="card-body">
            <form action="/parametres" method="POST" style="max-width:520px">
              <div class="form-group">
                <label class="form-label">Nom du parking</label>
                <input type="text" name="nom_parking" class="form-control"
                  value="<%= site.nom_parking || adminSite %>" placeholder="Ex: SAS Parking Cotonou" required>
              </div>
              <div class="form-group">
                <label class="form-label">Ville</label>
                <input type="text" name="ville" class="form-control"
                  value="<%= site.ville || adminVille %>" placeholder="Ex: Cotonou" required>
              </div>
              <div class="form-group">
                <label class="form-label">Capacité (nombre de places)</label>
                <input type="number" name="capacite" class="form-control" min="1" max="9999"
                  value="<%= site.capacite || 50 %>">
              </div>
              <div class="form-group">
                <label class="form-label">Téléphone du site</label>
                <input type="text" class="form-control" value="<%= site.telephone || '' %>" disabled
                  style="background:#f9fafb;color:#9ca3af" placeholder="Non modifiable ici">
                <span class="form-hint">Contactez le support pour modifier le téléphone.</span>
              </div>
              <button type="submit" class="btn btn-primary">💾 Enregistrer les modifications</button>
            </form>
          </div>
        </div>

        <!-- Carte infos système -->
        <div class="card mt-24">
          <div class="card-header">
            <div class="card-title">Informations système</div>
          </div>
          <div class="card-body">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px">
              <div class="stat-card" style="padding:16px">
                <div class="stat-icon green" style="font-size:20px">🆔</div>
                <div class="stat-value" style="font-size:16px">#<%= site.id || '—' %></div>
                <div class="stat-label">ID du site</div>
              </div>
              <div class="stat-card" style="padding:16px">
                <div class="stat-icon blue" style="font-size:20px">📅</div>
                <div class="stat-value" style="font-size:16px">
                  <%= site.created_at ? new Date(site.created_at).toLocaleDateString('fr-FR') : '—' %>
                </div>
                <div class="stat-label">Date de création</div>
              </div>
              <div class="stat-card" style="padding:16px">
                <div class="stat-icon orange" style="font-size:20px"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="6" cy="17" r="3"/><circle cx="18" cy="17" r="3"/><path d="M6 17l4-7h4l2-3M14 10l2 7"/></svg></div>
                <div class="stat-value" style="font-size:16px"><%= site.capacite || 50 %></div>
                <div class="stat-label">Places totales</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ONGLET 2 : TARIFICATION -->
      <div class="tab-panel" id="tab-tarifs" style="display:none">
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Historique des tarifs</div>
              <div class="card-sub">5 derniers tarifs configurés</div>
            </div>
            <a href="/dashboard" class="btn btn-primary btn-sm">+ Nouveau tarif</a>
          </div>
          <div class="card-body" style="padding:0">
            <% if (!tarifs || tarifs.length === 0) { %>
              <div style="padding:40px;text-align:center;color:#9ca3af">
                <div style="font-size:40px;margin-bottom:8px">💰</div>
                Aucun tarif configuré.
                <a href="/dashboard" style="color:#15803d;display:block;margin-top:8px">Configurer un tarif →</a>
              </div>
            <% } else { %>
              <table class="table">
                <thead>
                  <tr>
                    <th>Mode</th>
                    <th>Tarif (FCFA)</th>
                    <th>Date</th>
                    <th>Statut</th>
                  </tr>
                </thead>
                <tbody>
                  <% tarifs.forEach(t => { %>
                    <tr>
                      <td>
                        <span class="badge <%= t.mode_tarifaire === 'heure' ? 'badge-blue' : 'badge-green' %>">
                          <%= t.mode_tarifaire === 'heure' ? '⏱ Par heure' : '📦 Garde fixe' %>
                        </span>
                      </td>
                      <td><strong><%= Number(t.prix_tarif).toLocaleString('fr-FR') %> FCFA</strong></td>
                      <td style="color:#6b7280;font-size:13px">
                        <%= new Date(t.created_at).toLocaleDateString('fr-FR', {day:'numeric',month:'short',year:'numeric'}) %>
                      </td>
                      <td>
                        <% if (t.actif) { %>
                          <span class="badge badge-green">✅ Actif</span>
                        <% } else { %>
                          <span class="badge" style="background:#f3f4f6;color:#6b7280">Archivé</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>

        <div class="card mt-24" style="background:linear-gradient(135deg,#15803d,#22c55e);border:none;color:white">
          <div class="card-body" style="padding:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px">
            <div>
              <div style="font-size:16px;font-weight:700;margin-bottom:4px">⚡ Modifier le tarif en vigueur</div>
              <div style="font-size:13px;opacity:.85">Rendez-vous sur le tableau de bord pour changer le tarif actif.</div>
            </div>
            <a href="/dashboard" class="btn" style="background:rgba(255,255,255,.2);color:white;border:1.5px solid rgba(255,255,255,.4)">
              Aller au dashboard
            </a>
          </div>
        </div>
      </div>

      <!-- ONGLET 3 : AGENTS ASSIGNÉS -->
      <div class="tab-panel" id="tab-agents" style="display:none">
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Agents de ce site</div>
              <div class="card-sub">Liste des agents rattachés à <%= adminSite %></div>
            </div>
            <a href="/agents" class="btn btn-primary btn-sm">+ Gérer les agents</a>
          </div>
          <div class="card-body" style="padding:0">
            <div style="padding:32px;text-align:center;color:#6b7280">
              <div style="font-size:36px;margin-bottom:12px">👥</div>
              <div style="font-weight:600;margin-bottom:4px">Gestion des agents</div>
              <div style="font-size:13px;margin-bottom:16px">Consultez et gérez l'ensemble de votre équipe depuis la page dédiée.</div>
              <a href="/agents" class="btn btn-primary">Voir tous les agents →</a>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /page-body -->

    <div class="page-footer">
      <span>© <%= new Date().getFullYear() %> SAS Parking. Tous droits réservés.</span>
      <div class="footer-links">
        <a href="#">Support</a>
        <a href="#">Confidentialité</a>
        <span style="color:#9ca3af">Powered by FedaPay</span>
      </div>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
<script>
  // Gestion des onglets
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).style.display = 'block';
    });
  });
</script>
</body>
</html>
