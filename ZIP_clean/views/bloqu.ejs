<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Paiement journalier — SAS Parking</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background:#f0fdf4;display:flex;align-items:center;justify-content:center;min-height:100vh">

<div style="max-width:480px;width:100%;padding:24px">

  <!-- Logo -->
  <div style="text-align:center;margin-bottom:32px">
    <div style="width:56px;height:56px;background:linear-gradient(135deg,#15803d,#22c55e);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 4px 16px rgba(34,197,94,.3)">
      <svg width="28" height="28" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24">
        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12h6M12 9v6"/>
      </svg>
    </div>
    <div style="font-size:20px;font-weight:800;color:#111827">SAS Parking</div>
    <div style="font-size:13px;color:#6b7280">Tableau de bord administrateur</div>
  </div>

  <!-- Card principale -->
  <div class="card" style="border:2px solid #22c55e">
    <div style="background:linear-gradient(135deg,#15803d,#22c55e);padding:24px;border-radius:10px 10px 0 0;text-align:center;color:white">
      <div style="font-size:13px;font-weight:600;opacity:.85;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">
        Contribution journalière
      </div>
      <div style="font-size:42px;font-weight:800;line-height:1">
        <%= Number(abonnement.montant).toLocaleString('fr-FR') %>
        <span style="font-size:18px;font-weight:500">FCFA</span>
      </div>
      <div style="font-size:12px;opacity:.8;margin-top:6px">
        <%= abonnement.pourcentage %>% du chiffre d'affaires du jour · <%= today %>
      </div>
    </div>

    <div class="card-body">
      <div style="font-size:14px;color:#374151;line-height:1.7;margin-bottom:20px;text-align:center">
        Bonjour <strong><%= adminNom %></strong>, une contribution journalière est due pour
        <strong><%= adminSite %></strong>. Réglez-la pour accéder au tableau de bord.
      </div>

      <% if (abonnement.montant == 0) { %>
        <div class="alert alert-success" style="margin-bottom:16px">
          Aucun chiffre d'affaires enregistré aujourd'hui. Accès libre.
        </div>
        <a href="/dashboard" class="btn btn-primary btn-full" style="height:48px">Accéder au dashboard</a>
      <% } else { %>
        <form action="/abonnement/payer" method="POST">
          <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px">
            <div class="payment-option selected" data-mode="especes" onclick="selectPayment('especes')" style="padding:16px;border-radius:10px;cursor:pointer">
              <div style="display:flex;align-items:center;gap:12px">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <rect x="2" y="6" width="20" height="12" rx="2"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <div>
                  <div style="font-weight:700;font-size:14px">Espèces</div>
                  <div style="font-size:12px;color:#6b7280">Paiement cash</div>
                </div>
              </div>
            </div>
            <div class="payment-option" data-mode="mobile" onclick="selectPayment('mobile')" style="padding:16px;border-radius:10px;cursor:pointer">
              <div style="display:flex;align-items:center;gap:12px">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/>
                </svg>
                <div>
                  <div style="font-weight:700;font-size:14px">Mobile Money</div>
                  <div style="font-size:12px;color:#6b7280">MTN, Moov, Airtel</div>
                </div>
              </div>
            </div>
          </div>
          <input type="hidden" name="mode" id="modeInput" value="especes">
          <button type="submit" class="btn btn-primary btn-full" style="height:52px;font-size:16px;font-weight:700">
            Confirmer le paiement
          </button>
        </form>
      <% } %>

      <div style="text-align:center;margin-top:16px">
        <a href="/logout" style="font-size:13px;color:#9ca3af;text-decoration:none">Se déconnecter</a>
      </div>
    </div>
  </div>

  <div style="text-align:center;margin-top:20px;font-size:12px;color:#9ca3af">
    © <%= new Date().getFullYear() %> SAS Parking · Contribution automatique
  </div>
</div>

<script src="/js/app.js"></script>
</body>
</html>