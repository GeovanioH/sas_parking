<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Connexion — SAS Parking</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="auth-page">
    <div class="auth-card">

      <div class="auth-header">
        <div class="auth-logo-wrap"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24">
            <circle cx="6" cy="17" r="3" />
            <circle cx="18" cy="17" r="3" />
            <path d="M6 17l4-7h4l2-3M14 10l2 7" />
          </svg></div>
        <div class="auth-title">SAS Parking</div>
        <div class="auth-subtitle">"La garde, simplifiée."</div>
      </div>

      <div class="auth-body">

        <!-- Onglets Administrateur / Agent -->
        <div class="auth-tabs" id="authTabs">
          <button class="auth-tab" id="tabAdmin" onclick="switchTab('admin')">Administrateur</button>
          <button class="auth-tab active" id="tabAgent" onclick="switchTab('agent')">Agent de terrain</button>
        </div>

        <% if (error) { %>
          <div class="alert alert-error alert-auto-dismiss">
            <span class="alert-icon">⚠️</span>
            <span>
              <%= error %>
            </span>
          </div>
          <% } %>
            <% if (success) { %>
              <div class="alert alert-success alert-auto-dismiss">
                <span class="alert-icon">✅</span>
                <span>
                  <%= success %>
                </span>
              </div>
              <% } %>

                <!-- Formulaire Admin -->
                <form id="formAdmin" action="/login" method="POST" style="display:none">
                  <div class="form-group">
                    <label class="form-label">Numéro de téléphone <span class="req">*</span></label>
                    <div class="form-control-icon">
                      <span class="icon">📱</span>
                      <input type="tel" name="telephone" class="form-control" placeholder="+229 XX XX XX XX"
                        value="<%= formData && formData.telephone ? formData.telephone : '' %>" required>
                    </div>
                  </div>
                  <div class="form-group">
                    <div class="flex-between mb-4">
                      <label class="form-label" style="margin:0">Mot de passe <span class="req">*</span></label>
                    </div>
                    <div class="form-control-icon">
                      <span class="icon">🔒</span>
                      <div style="position:relative">
                        <input type="password" name="mot_de_passe" id="mdp-login" class="form-control"
                          placeholder="••••••••" required>
                        <button type="button" onclick="toggleMdp('mdp-login')"
                          style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;display:flex;align-items:center">
                          <svg id="eye-mdp-login" width="18" height="18" fill="none" stroke="currentColor"
                            stroke-width="2" viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                  <button type="submit" class="btn btn-primary btn-full btn-lg mt-8">
                    Se connecter →
                  </button>
                  <div style="text-align:center;margin-top:12px">
                    <a href="/reset?role=admin" style="font-size:13px;color:#6b7280;text-decoration:none">
                      Mot de passe oublié ?
                    </a>
                  </div>
                  <div class="text-center mt-16" style="font-size:13px;color:#6b7280">
                    Pas encore de compte ?
                    <a href="/signup" style="color:#15803d;font-weight:600">Créer un site</a>
                  </div>
                </form>

                <!-- Formulaire Agent -->
                <form id="formAgent" action="/agent/login" method="POST">
                  <div class="form-group">
                    <label class="form-label">Identifiant agent <span class="req">*</span></label>
                    <div class="form-control-icon">
                      <span class="icon">🛡️</span>
                      <input type="tel" name="numero" class="form-control" placeholder="AGENT-229-XXX"
                        value="<%= formData && formData.numero ? formData.numero : '' %>" required>
                    </div>
                  </div>
                  <div class="form-group">
                    <div class="flex-between" style="margin-bottom:6px">
                      <label class="form-label" style="margin:0">Code PIN <span class="req">*</span></label>
                    </div>
                    <div class="form-control-icon">
                      <span class="icon">🔒</span>
                      <div style="position:relative">
                        <input type="password" name="mot_de_passe" id="mdp-ag" class="form-control"
                          placeholder="••••••••" required>
                        <button type="button" onclick="toggleMdp('mdp-ag')"
                          style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;display:flex;align-items:center">
                          <svg id="eye-mdp-ag" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                            viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                          </svg>
                        </button>
                      </div>
                      
                    </div>
                  </div>
                  <div class="form-group">
                    <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#6b7280;cursor:pointer">
                      <input type="checkbox" name="remember"> Se souvenir de moi sur cet appareil
                    </label>
                  </div>
                  <button type="submit" class="btn btn-primary btn-full btn-lg">
                    Se connecter →
                  </button>
                  <div class="alert alert-info mt-16" style="font-size:12px">
                    <span>ℹ️</span>
                    <span>Les agents de terrain doivent utiliser le Code PIN fourni par leur superviseur de site.</span>
                  </div>
                </form>

      </div>

      <div class="auth-footer">
        <div style="margin-bottom:6px">
          🔒 PAIEMENT SÉCURISÉ — Propulsé par <strong>FedaPay</strong>
        </div>
        © <%= new Date().getFullYear() %> SAS Parking Bénin — Tous droits réservés
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    function switchTab(mode) {
      document.getElementById('formAdmin').style.display = mode === 'admin' ? 'block' : 'none';
      document.getElementById('formAgent').style.display = mode === 'agent' ? 'block' : 'none';
      document.getElementById('tabAdmin').classList.toggle('active', mode === 'admin');
      document.getElementById('tabAgent').classList.toggle('active', mode === 'agent');
    }
    // Afficher agent par défaut
    switchTab('agent');
  </script>
  <script>
    function toggleMdp(id) {
      const input = document.getElementById(id);
      const isVisible = input.type === 'text';
      input.type = isVisible ? 'password' : 'text';
      const eye = document.getElementById('eye-' + id);
      eye.innerHTML = isVisible
        ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
        : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
    }
  </script>
  <script>
function toggleMdp(id) {
  const input = document.getElementById(id);
  const isVisible = input.type === 'text';
  input.type = isVisible ? 'password' : 'text';
  const eye = document.getElementById('eye-' + id);
  eye.innerHTML = isVisible
    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
    : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
}
</script>
</body>

</html>