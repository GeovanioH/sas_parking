<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Connexion Agent — SAS Parking</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-page">
  <div class="auth-card">

    <div class="auth-header">
      <div class="auth-logo-wrap">🛡️</div>
      <div class="auth-title">Agent de Terrain</div>
      <div class="auth-subtitle">Interface opérationnelle sécurisée</div>
    </div>

    <div class="auth-body">
      <% if (error) { %>
        <div class="alert alert-error alert-auto-dismiss">
          <span class="alert-icon">⚠️</span><span><%= error %></span>
        </div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success">
          <span class="alert-icon">✅</span><span><%= success %></span>
        </div>
      <% } %>

      <form action="/agent/login" method="POST">
        <div class="form-group">
          <label class="form-label">Identifiant agent <span class="req">*</span></label>
          <div class="form-control-icon">
            <span class="icon">📱</span>
            <input type="tel" name="numero" class="form-control"
              placeholder="Votre numéro de téléphone"
              value="<%= formData && formData.numero ? formData.numero : '' %>"
              autofocus required>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Code PIN <span class="req">*</span></label>
          <div class="form-control-icon" style="position:relative">
            <span class="icon">🔒</span>
            <input type="password" minlength="4" maxlength="10" title="Entre 4 et 10 caractères" name="mot_de_passe" id="mdp-ag" class="form-control"
              placeholder="••••••" maxlength="10" required>
            <button type="button" onclick="toggleMdp('mdp-ag')"
              style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;display:flex;align-items:center">
              <svg id="eye-mdp-ag" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-full btn-lg">
          Se connecter →
        </button>
        <div style="text-align:center;margin-top:12px">
  <a href="/reset?role=agent" style="font-size:13px;color:#6b7280;text-decoration:none">
    Mot de passe oublié ?
  </a>
</div>
      </form>

      <div class="alert alert-info mt-16" style="font-size:12px">
        <span>ℹ️</span>
        <span>Les agents de terrain doivent utiliser le Code PIN fourni par leur superviseur de site pour toute session active.</span>
      </div>

      <div class="text-center mt-16" style="font-size:13px;color:#6b7280">
        Vous êtes administrateur ? <a href="/login" style="color:#15803d;font-weight:600">Espace admin</a>
      </div>
    </div>

    <div class="auth-footer">
      🔒 PAIEMENT SÉCURISÉ — Propulsé par <strong>FedaPay</strong><br>
      © <%= new Date().getFullYear() %> SAS Parking Bénin
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
<script>
function toggleMdp(id) {
  const input = document.getElementById(id);
  const isVisible = input.type === 'text';
  input.type = isVisible ? 'password' : 'text';
  const eye = document.getElementById('eye-' + id);
  eye.innerHTML = isVisible
    ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
    : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
}
</script>
</body>
</html>
