<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Nouveau mot de passe — SAS Parking</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background:#f0fdf4;display:flex;align-items:center;justify-content:center;min-height:100vh">

<div style="max-width:420px;width:100%;padding:24px">

  <div style="text-align:center;margin-bottom:32px">
    <div style="width:52px;height:52px;background:linear-gradient(135deg,#15803d,#22c55e);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 4px 16px rgba(34,197,94,.3)">
      <svg width="26" height="26" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <div style="font-size:20px;font-weight:800;color:#111827">Nouveau mot de passe</div>
    <div style="font-size:13px;color:#6b7280;margin-top:4px">Entrez le code reçu par SMS et votre nouveau mot de passe</div>
  </div>

  <div class="card">
    <div class="card-body">

      <% if (error) { %>
        <div class="alert alert-error" style="margin-bottom:16px">
          <span>⚠️</span>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/reset/nouveau" method="POST">
        <input type="hidden" name="telephone" value="<%= telephone %>">
        <input type="hidden" name="role" value="<%= role %>">

        <div class="form-group">
          <label class="form-label">Code reçu par SMS</label>
          <input type="text" name="token" class="form-control" required
            maxlength="6" placeholder="123456"
            style="height:56px;font-size:28px;font-family:monospace;font-weight:700;text-align:center;letter-spacing:6px">
          <span class="form-hint">Code valable 30 minutes</span>
        </div>

        <div class="form-group">
          <label class="form-label">Nouveau mot de passe</label>
          <div style="position:relative">
            <input type="password" name="mot_de_passe" id="mdp1" class="form-control" required
              minlength="6" placeholder="Minimum 6 caractères"
              style="height:48px;padding-right:44px">
            <button type="button" onclick="toggleMdp('mdp1', this)"
              style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;display:flex;align-items:center">
              <svg id="eye-mdp1" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Confirmer le mot de passe</label>
          <div style="position:relative">
            <input type="password" name="confirmer" id="mdp2" class="form-control" required
              minlength="6" placeholder="Répétez le mot de passe"
              style="height:48px;padding-right:44px">
            <button type="button" onclick="toggleMdp('mdp2', this)"
              style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#9ca3af;display:flex;align-items:center">
              <svg id="eye-mdp2" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div style="margin:-8px 0 16px">
          <div style="height:4px;background:#e5e7eb;border-radius:2px;overflow:hidden">
            <div id="strengthBar" style="height:100%;width:0%;transition:.3s;border-radius:2px"></div>
          </div>
          <div id="strengthText" style="font-size:11px;color:#9ca3af;margin-top:4px"></div>
        </div>

        <button type="submit" class="btn btn-primary btn-full"
          style="height:50px;font-size:15px;font-weight:700">
          Réinitialiser le mot de passe
        </button>
      </form>

      <div style="text-align:center;margin-top:16px">
        <a href="/reset" style="font-size:13px;color:#6b7280;text-decoration:none">
          ← Renvoyer un code
        </a>
      </div>

    </div>
  </div>
</div>

<script>
function toggleMdp(id) {
  const input = document.getElementById(id);
  const isVisible = input.type === 'text';
  input.type = isVisible ? 'password' : 'text';

  const eye = document.getElementById('eye-' + id);
  if (isVisible) {
    // Œil normal (mot de passe caché)
    eye.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  } else {
    // Œil barré (mot de passe visible)
    eye.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
  }
}

document.getElementById('mdp1').addEventListener('input', function () {
  const v = this.value;
  let score = 0;
  if (v.length >= 6)           score++;
  if (v.length >= 10)          score++;
  if (/[A-Z]/.test(v))        score++;
  if (/[0-9]/.test(v))        score++;
  if (/[^A-Za-z0-9]/.test(v)) score++;

  const colors = ['#ef4444','#f97316','#eab308','#22c55e','#15803d'];
  const labels = ['Très faible','Faible','Moyen','Fort','Très fort'];
  const bar    = document.getElementById('strengthBar');
  const label  = document.getElementById('strengthText');

  bar.style.width      = (score * 20) + '%';
  bar.style.background = colors[score - 1] || '#e5e7eb';
  label.textContent    = score > 0 ? labels[score - 1] : '';
});
</script>

</body>
</html>