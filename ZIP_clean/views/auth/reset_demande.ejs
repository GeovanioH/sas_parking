<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Mot de passe oublié — SAS Parking</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background:#f0fdf4;display:flex;align-items:center;justify-content:center;min-height:100vh">

<div style="max-width:420px;width:100%;padding:24px">

  <div style="text-align:center;margin-bottom:32px">
    <div style="width:52px;height:52px;background:linear-gradient(135deg,#15803d,#22c55e);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;box-shadow:0 4px 16px rgba(34,197,94,.3)">
      <svg width="26" height="26" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div style="font-size:20px;font-weight:800;color:#111827">Mot de passe oublié</div>
    <div style="font-size:13px;color:#6b7280;margin-top:4px">Recevez un code de réinitialisation par SMS</div>
  </div>

  <div class="card">
    <div class="card-body">

      <% if (error) { %>
        <div class="alert alert-error" style="margin-bottom:16px">
          <span>⚠️</span>
          <span><%= error %></span>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success" style="margin-bottom:16px">
          <span>✅</span>
          <span><%= success %></span>
        </div>
      <% } %>

      <form action="/reset" method="POST">

        <div class="form-group">
          <label class="form-label">Type de compte</label>
          <div style="display:flex;gap:10px;margin-top:6px">
            <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 14px;border:2px solid <%= role==='admin' ? '#22c55e' : '#e5e7eb' %>;border-radius:8px;cursor:pointer;font-size:14px;font-weight:600;color:<%= role==='admin' ? '#15803d' : '#6b7280' %>">
              <input type="radio" name="role" value="admin" <%= role==='admin' ? 'checked' : '' %> style="display:none" onchange="this.form.submit()">
              👔 Administrateur
            </label>
            <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 14px;border:2px solid <%= role==='agent' ? '#22c55e' : '#e5e7eb' %>;border-radius:8px;cursor:pointer;font-size:14px;font-weight:600;color:<%= role==='agent' ? '#15803d' : '#6b7280' %>">
              <input type="radio" name="role" value="agent" <%= role==='agent' ? 'checked' : '' %> style="display:none" onchange="this.form.submit()">
              🛡️ Agent
            </label>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Numéro de téléphone</label>
          <input type="tel" name="telephone" class="form-control"
            placeholder="+229 XX XX XX XX" required
            style="height:48px">
          <span class="form-hint">Le numéro associé à votre compte</span>
        </div>

        <button type="submit" class="btn btn-primary btn-full" style="height:50px;font-size:15px;font-weight:700">
          Envoyer le code SMS →
        </button>
      </form>

      <div style="text-align:center;margin-top:16px">
        <a href="/login" style="font-size:13px;color:#6b7280;text-decoration:none">
          ← Retour à la connexion
        </a>
      </div>
    </div>
  </div>
</div>

</body>
</html>