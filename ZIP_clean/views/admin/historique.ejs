<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Historique Sessions — SAS Parking Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<button class="menu-toggle" onclick="toggleSidebar()">☰</button>

<div class="app-layout">
  <%- include('../composants/sidebar_admin', { page: 'historique', adminNom, adminPrenom }) %>

  <div class="main-content">
    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-left">
        <div class="topbar-title">Historique Sessions</div>
        <div class="topbar-sub"><%= sessions.length %> session(s) trouvée(s)</div>
      </div>
      <div class="topbar-right">
        <div class="topbar-user">
          <div class="topbar-avatar"><%= (adminNom||'A')[0].toUpperCase() %></div>
          <div>
            <div class="topbar-user-name"><%= adminNom %> <%= adminPrenom %></div>
            <div class="topbar-user-role">Administrateur</div>
          </div>
          <div class="topbar-online-dot"></div>
        </div>
      </div>
    </div>

    <div class="page-body">
      <% if (error) { %>
        <div class="alert alert-error alert-auto-dismiss"><span>⚠️</span><span><%= error %></span></div>
      <% } %>

      <!-- FILTRES -->
      <div class="card">
        <div class="card-body">
          <form action="/historique" method="GET" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end">
            <div class="form-group" style="margin:0;flex:2;min-width:180px">
              <label class="form-label">Recherche (plaque / code)</label>
              <input type="text" name="search" class="form-control" value="<%= search %>"
                placeholder="🔍 Ex: BJ1234 ou ABC1">
            </div>
            <div class="form-group" style="margin:0;flex:1;min-width:140px">
              <label class="form-label">Agent</label>
              <select name="agent" class="form-control">
                <option value="">Tous les agents</option>
                <% agents.forEach(a => { %>
                  <option value="<%= a.id %>" <%= agentId == a.id ? 'selected' : '' %>>
                    <%= a.nom %> <%= a.prenom %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="margin:0;flex:1;min-width:140px">
              <label class="form-label">Statut</label>
              <select name="filtre" class="form-control">
                <option value="toutes"   <%= filtre === 'toutes'   ? 'selected' : '' %>>Toutes</option>
                <option value="en_cours" <%= filtre === 'en_cours' ? 'selected' : '' %>>En cours</option>
                <option value="cloture"  <%= filtre === 'cloture'  ? 'selected' : '' %>>Clôturées</option>
              </select>
            </div>
            <div class="form-group" style="margin:0;flex:1;min-width:140px">
              <label class="form-label">Date</label>
              <input type="date" name="date" class="form-control" value="<%= date %>">
            </div>
            <div style="display:flex;gap:8px">
              <button type="submit" class="btn btn-primary">🔍 Filtrer</button>
              <a href="/historique" class="btn btn-outline">✕ Reset</a>
            </div>
          </form>
        </div>
      </div>

      <!-- TABLE SESSIONS -->
      <div class="card mt-24">
        <div class="card-header">
          <div>
            <div class="card-title">Toutes les sessions</div>
            <div class="card-sub">Entrées, sorties et statuts complets</div>
          </div>
          <span class="badge badge-green"><%= sessions.length %> résultats</span>
        </div>
        <div class="card-body" style="padding:0">
          <% if (sessions.length === 0) { %>
            <div style="padding:48px;text-align:center;color:#9ca3af">
              <div style="font-size:40px;margin-bottom:8px">📂</div>
              <div style="font-weight:600;margin-bottom:4px">Aucune session trouvée</div>
              <div style="font-size:13px">Modifiez les filtres ou vérifiez les données.</div>
            </div>
          <% } else { %>
            <div style="overflow-x:auto">
              <table class="table">
                <thead>
                  <tr>
                    <th>Plaque</th>
                    <th>Code</th>
                    <th>Client</th>
                    <th>Agent</th>
                    <th>Entrée</th>
                    <th>Sortie</th>
                    <th>Durée</th>
                    <th>Montant</th>
                    <th>Paiement</th>
                    <th>Statut</th>
                  </tr>
                </thead>
                <tbody>
                  <% sessions.forEach(s => {
                    const entree = new Date(s.heure_entree);
                    const sortie = s.heure_sortie ? new Date(s.heure_sortie) : null;
                    let dureeStr = '—';
                    if (sortie) {
                      const diffMs = sortie - entree;
                      const h = Math.floor(diffMs / 3600000);
                      const m = Math.floor((diffMs % 3600000) / 60000);
                      dureeStr = h > 0 ? `${h}h ${m}m` : `${m}m`;
                    }
                  %>
                    <tr>
                      <td><strong style="font-family:monospace;letter-spacing:.5px"><%= s.plaque %></strong></td>
                      <td>
                        <span class="code-hex-display" style="font-size:12px;cursor:pointer" title="Cliquer pour copier">
                          <%= s.code_hex %>
                        </span>
                      </td>
                      <td style="font-size:13px">
                        <%= s.nom_client || '' %> <%= s.prenom_client || '' %>
                        <% if (!s.nom_client && !s.prenom_client) { %><span style="color:#d1d5db">—</span><% } %>
                      </td>
                      <td style="font-size:13px"><%= s.agent_nom %> <%= s.agent_prenom %></td>
                      <td style="font-size:12px;color:#6b7280">
                        <%= entree.toLocaleTimeString('fr-FR', {hour:'2-digit',minute:'2-digit'}) %>
                        <div style="font-size:11px"><%= entree.toLocaleDateString('fr-FR') %></div>
                      </td>
                      <td style="font-size:12px;color:#6b7280">
                        <% if (sortie) { %>
                          <%= sortie.toLocaleTimeString('fr-FR', {hour:'2-digit',minute:'2-digit'}) %>
                          <div style="font-size:11px"><%= sortie.toLocaleDateString('fr-FR') %></div>
                        <% } else { %>
                          <span style="color:#22c55e;font-weight:600">EN COURS</span>
                        <% } %>
                      </td>
                      <td style="font-size:13px;color:#6b7280"><%= dureeStr %></td>
                      <td style="font-weight:600;color:#15803d">
                        <% if (s.montant) { %><%= Number(s.montant).toLocaleString('fr-FR') %> <span style="font-weight:400;font-size:11px">FCFA</span><% } else { %>—<% } %>
                      </td>
                      <td>
                        <% if (s.mode_paiement === 'mobile_money') { %>
                          <span class="badge badge-green">📱 Mobile</span>
                        <% } else if (s.mode_paiement === 'especes') { %>
                          <span class="badge" style="background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0">💵 Espèces</span>
                        <% } else { %>
                          <span style="color:#d1d5db">—</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (s.statut === 'en_cours') { %>
                          <span class="badge badge-orange">🌀 En cours</span>
                        <% } else if (s.statut === 'cloture') { %>
                          <span class="badge badge-green">✅ Clôturé</span>
                        <% } else { %>
                          <span class="badge" style="background:#fef2f2;color:#dc2626">Annulé</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

    </div><!-- /page-body -->

    <div class="page-footer">
      <span>© <%= new Date().getFullYear() %> SAS Parking. Tous droits réservés.</span>
      <div class="footer-links">
        <a href="#">Support</a>
        <a href="#">Confidentialité</a>
        <span style="color:#9ca3af">Powered by FedaPay</span>
      </div>
    </div>
  </div>
</div>

<script src="/js/app.js"></script>
</body>
</html>
